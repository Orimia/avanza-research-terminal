# =============================================================================
# avanza-research-terminal — environment variables
# Copy this file to .env and fill in the keys you have. ALL are optional:
# with no keys the terminal runs fully on deterministic MOCK data so you can
# explore the UI. Real clients activate automatically when their key is present.
#
# This project NEVER asks for Avanza credentials and has no broker login.
# Do not add Avanza username/password/BankID anything here. There is nowhere
# in the code that would use them.
# =============================================================================

# --- Nordic primary data (Börsdata) ---
BORSDATA_API_KEY=

# --- Global data (US / EU). Provide one or both. ---
EODHD_API_KEY=
FINNHUB_API_KEY=

# --- FX (USD/SEK, EUR/SEK). Optional: a free static fallback is built in. ---
# If set, the fx_client may call a live FX endpoint (every call is logged).
FX_API_KEY=

# --- Optional alerts ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
ALERT_EMAIL_SMTP_HOST=
ALERT_EMAIL_SMTP_PORT=587
ALERT_EMAIL_USERNAME=
ALERT_EMAIL_PASSWORD=
ALERT_EMAIL_TO=

# --- Optional LLM memo generation ---
# The deterministic scoring + memo engine works WITHOUT this. Only set it if
# you want narrative memos written by an LLM. Memo generation is isolated in an
# optional module and is never required for a recommendation.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-8

# --- Behaviour flags ---
# Allow live network calls to data providers (set false to force mock even if
# keys exist — useful for offline/dev). Every outbound call is logged.
ALLOW_NETWORK=true
